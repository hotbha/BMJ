{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Backend: Clean Build",
			"type": "shell",
			"command": "cd ${workspaceFolder}/bmjServer && ./mvnw clean verify",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": ["$maven"],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Backend: Run Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder}/bmjServer && ./mvnw test",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": ["$maven"],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Backend: Run Spring Boot",
			"type": "shell",
			"command": "cd ${workspaceFolder}/bmjServer && ./mvnw spring-boot:run",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Started.*",
					"endsPattern": "^.*Tomcat started.*"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Get Dependencies",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter pub get",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Analyze",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter analyze",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Run (Debug)",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter run --dart-define=API_BASE_URL=http://localhost:8080",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": false,
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Run Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter test --dart-define=API_BASE_URL=http://localhost:8080",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: E2E Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter test integration_test --dart-define=API_BASE_URL=http://localhost:8080 --dart-define=E2E=true --dart-define=E2E_USER=9876543210 --dart-define=E2E_PASS=TestPass@123",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
