{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Backend: Clean Build",
			"type": "shell",
			"command": "cd ${workspaceFolder}/bmjServer && ./mvnw clean verify",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": ["$maven"],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Backend: Run Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder}/bmjServer && ./mvnw test",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": ["$maven"],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Backend: Run Spring Boot",
			"type": "shell",
			"command": "cd ${workspaceFolder}/bmjServer && ./mvnw spring-boot:run",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^.*$",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^.*Started.*",
					"endsPattern": "^.*Tomcat started.*"
				}
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Get Dependencies",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter pub get",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Analyze",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter analyze",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Run (Debug)",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter run --dart-define=API_BASE_URL=http://localhost:8080",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": false,
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Run on Phone (Debug)",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && $ip=$((Get-NetIPAddress -AddressFamily IPv4 -PrefixOrigin Dhcp | Where-Object { $_.IPAddress -notlike '127.*' -and $_.IPAddress -notlike '172.*' -and $_.IPAddress -notlike '169.254.*' } | Select-Object -First 1 -ExpandProperty IPAddress)); Write-Host \"Detected IP: $ip\"; flutter run --dart-define=API_BASE_URL=http://${ip}:8080",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"isBackground": false,
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			},
			"problemMatcher": []
		},
		{
			"label": "Flutter: Show Detected IP",
			"type": "shell",
			"command": "powershell -Command \"$ip=Get-NetIPAddress -AddressFamily IPv4 -PrefixOrigin Dhcp | Where-Object { $_.IPAddress -notlike '127.*' -and $_.IPAddress -notlike '172.*' -and $_.IPAddress -notlike '169.254.*' } | Select-Object -First 1 -ExpandProperty IPAddress; Write-Host 'Your machine IP: ' -NoNewline; Write-Host $ip -ForegroundColor Green; Write-Host 'Use this in: --dart-define=API_BASE_URL=http://'$ip':8080' -ForegroundColor Cyan\"",
			"group": "none",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			},
			"problemMatcher": []
		},

		{
			"label": "Flutter: Run Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter test --dart-define=API_BASE_URL=http://localhost:8080",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: E2E Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter test integration_test --dart-define=API_BASE_URL=http://localhost:8080 --dart-define=E2E=true --dart-define=E2E_USER=9876543210 --dart-define=E2E_PASS=TestPass@123",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Run All Tests",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Run on Physical Device",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:physical",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Run on Emulator",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:emulator",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Run with Video",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:video",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Run with Reporting",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:report",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Clean Reports",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:clean",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Complete Flow Test",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:full",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "E2E: Checkout Flow",
			"type": "shell",
			"command": "cd ${workspaceFolder} && npm run e2e:checkout",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Make: Test E2E",
			"type": "shell",
			"command": "cd ${workspaceFolder} && make test-e2e",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Make: Test Physical Device",
			"type": "shell",
			"command": "cd ${workspaceFolder} && make test-physical",
			"group": {
				"kind": "test",
				"isDefault": false
			},
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Flutter: Build APK",
			"type": "shell",
			"command": "cd ${workspaceFolder}/lush && flutter build apk --dart-define=API_BASE_URL=https://api.bookmyjuice.co.in",
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Database: Check Connection",
			"type": "shell",
			"command": "mysql -h localhost -u bmj -pPASS@123 bmj_db -e 'SELECT 1 AS connection_ok;'",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			}
		},
		{
			"label": "Start MySQL (if needed)",
			"type": "shell",
			"command": "echo \"✅ MySQL is expected to be running in Docker. Run 'docker-compose up -d' if not already started.\"",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"panel": "new"
			},
			"problemMatcher": []
		},
		{
			"label": "Docker: Start Services",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -Command \"$running = docker ps --format '{{.Names}}' | Where-Object { $_ -eq 'bmj-backend' }; if (-not $running) { Write-Host 'Starting Docker services...'; docker-compose up -d | Out-Null }; $count = 0; do { $r = try { (Invoke-WebRequest -Uri http://localhost:8080/api/health -TimeoutSec 2 -UseBasicParsing).StatusCode } catch { $null }; if ($r -eq 200) { Write-Host 'Backend is ready!' -ForegroundColor Green; exit 0 }; Write-Host ('Waiting for backend... (' + [string]($count * 3) + 's)'); Start-Sleep -Seconds 3; $count++ } while ($count -lt 20); Write-Host 'ERROR: Backend did not start within 60 seconds. Run docker-compose up -d manually.' -ForegroundColor Red; exit 1\"",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"panel": "new"
			},
			"problemMatcher": []
		}

	]
}

