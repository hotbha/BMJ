# ============================================================
# BookMyJuice — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is gitignored — never commit real secrets.
# ============================================================

# ============================================================
# Database — MySQL
# ============================================================
DB_USERNAME=db
DB_PASSWORD=pwd$8
DB_HOSTNAME=localhost
DB_PORT=3306
DB_NAME=db

# ============================================================
# Spring Security — Admin
# ============================================================
ADMIN_USER=admin
ADMIN_PASSWORD=<CHANGE_ME>

# ============================================================
# Chargebee — Subscription & Billing
# ============================================================
CHARGEBEE_SITE=test
CHARGEBEE_API_KEY=<YOUR_CHARGEBEE_API_KEY>

# ============================================================
# JWT — Authentication Tokens
# ============================================================
JWT_SECRET=<CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING>

# ============================================================
# Webhook — Chargebee Event Ingestion
# ============================================================
WEBHOOK_USERNAME=<CHANGE_ME>
WEBHOOK_PASSWORD=<CHANGE_ME>

# ============================================================
# Email — SMTP (Gmail default)
# ============================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=support@gmail.co.in
MAIL_PASSWORD=<YOUR_SMTP_PASSWORD>
MAIL_FROM=support@bookmyjuice.co.in

# ============================================================
# Google OAuth — Client
# ============================================================
GOOGLE_CLIENT_ID=24122477606-tju3ortu42psbfluvl9hvmj7q15ec64c.apps.googleusercontent.com

# ============================================================
# Redis — Cache
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# Flutter Frontend (build-time, for local dev)
# Used via: flutter build --dart-define=API_BASE_URL=http://...
# ============================================================
API_BASE_URL=http://localhost:8080

# ============================================================
# Sentry — Error Tracking
# ============================================================
# Backend DSN (Spring Boot) — get from sentry.io
SENTRY_DSN_BACKEND=
# Flutter DSN (Dart/Flutter) — get from sentry.io
SENTRY_DSN_FLUTTER=
# Environment tag for Sentry events
SENTRY_ENVIRONMENT=development
